{
    "manifest_version": 3,
    "name": "WebMark",
    "version": "1.0",
    "description": "A web based highlighting extension with sticky notes.",
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["storage.js","content.js"],
            "css": ["content.css"]  
        }
    ],

    "background": {
        "service_worker" : "background.js"
    }
}

